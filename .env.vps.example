# Portas expostas apenas para o host
WEB_PORT=3001
API_PORT=8081
POSTGRES_PORT=5433

# Build/release do Deploy Tool
REGISTRY_URL=ghcr.io
REGISTRY_NAMESPACE=sotorivaxl
RELEASE_TAG=latest
DEPLOY_NETWORK_NAME=ioauto_network
DB_HOST=ioauto_postgres

# URLs publicas
# `ioauto.ioconnect.com.br` e `app.ioauto.ioconnect.com.br` podem apontar para o mesmo container `web`.
# Mantemos `app.ioauto.ioconnect.com.br` como URL canonica do app autenticado.
NEXT_PUBLIC_APP_URL=https://app.ioauto.ioconnect.com.br
NEXT_PUBLIC_API_BASE=https://api.ioauto.ioconnect.com.br
API_INTERNAL_BASE=http://api:8080
APP_PUBLIC_URL=https://app.ioauto.ioconnect.com.br
APP_CORS_ALLOWED_ORIGINS=https://ioauto.ioconnect.com.br,https://app.ioauto.ioconnect.com.br

# Frontend / auth
# Deve ser exatamente igual ao JWT_SECRET da API
JWT_SECRET_FOR_MIDDLEWARE=troque-por-um-segredo-forte
AUTH_COOKIE_SECURE=true

# Postgres (container)
POSTGRES_DB=ioauto_appdb
POSTGRES_USER=ioauto
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# API / JWT / criptografia
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=troque-por-um-segredo-forte
APP_DB_ENCRYPTION_KEY=troque-por-uma-chave-forte
JAVA_OPTS=-Xms256m -Xmx1024m
NEXT_PUBLIC_USE_MOCK_AI_SUPERVISORS=false

# Redis existente na VPS
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1

# Asaas Billing
ASAAS_API_KEY=$aact_xxxxx
ASAAS_WEBHOOK_TOKEN=seu-token-configurado-no-webhook
ASAAS_API_BASE_URL=https://api.asaas.com/v3
ASAAS_CHECKOUT_BASE_URL=https://asaas.com
ASAAS_BILLING_TYPES=CREDIT_CARD,BOLETO
IOAUTO_PLAN_KEY=ioauto-growth
IOAUTO_PLAN_NAME=IOAuto Growth
IOAUTO_PLAN_DESCRIPTION=Assinatura recorrente do IOAuto
IOAUTO_PLAN_VALUE=349.00
IOAUTO_PLAN_CYCLE=MONTHLY

# Integracoes operacionais
# A configuracao por tenant e feita dentro da plataforma.
# Estas variaveis servem apenas para o ambiente da aplicacao.
ZAPI_WEBHOOK_PUBLIC_BASE=https://api.ioauto.ioconnect.com.br
WEBMOTORS_DEFAULT_ENDPOINT=
